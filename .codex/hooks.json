{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/session_start_context.py\"",
            "timeout": 15,
            "statusMessage": "Loading project context"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/user_prompt_submit_guard.py\"",
            "timeout": 10,
            "statusMessage": "Checking prompt safety"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^Bash$|^apply_patch$|Edit|Write|^mcp__",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/pre_tool_use_policy.py\"",
            "timeout": 10,
            "statusMessage": "Checking tool use policy"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "^Bash$|^apply_patch$|Edit|Write|^mcp__",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/permission_request_policy.py\"",
            "timeout": 10,
            "statusMessage": "Checking approval request"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^Bash$|^apply_patch$|Edit|Write|^mcp__",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/post_tool_use_review.py\"",
            "timeout": 10,
            "statusMessage": "Reviewing tool output"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/stop_quality_gate.py\"",
            "timeout": 10,
            "statusMessage": "Running final quality gate"
          }
        ]
      }
    ]
  }
}
